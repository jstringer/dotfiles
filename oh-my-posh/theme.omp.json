{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "foreground": "#282828",
          "background": "#458588",
          "template": " \uE62A "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ebdbb2",
          "background": "#3c3836",
          "properties": {
            "style": "folder",
            "max_depth": 3,
            "folder_separator_icon": " \ue0b1 "
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#282828",
          "background": "#b8bb26",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#282828{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#282828{{ end }}",
            "{{ if gt .Ahead 0 }}#282828{{ end }}"
          ],
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#fe8019{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#fb4934{{ end }}",
            "{{ if gt .Ahead 0 }}#b8bb26{{ end }}"
          ],
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }} ",
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "branch_icon": "\ue725 "
          }
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#282828",
          "background": "#b8bb26",
          "template": "  {{ .Full }} ",
          "properties": {
            "display_mode": "files"
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#282828",
          "background": "#fabd2f",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "properties": {
            "display_mode": "files"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#928374",
          "template": "{{ .FormattedMs }} ",
          "properties": {
            "threshold": 2000,
            "style": "austin"
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "#928374",
          "template": "\uf017 {{ .CurrentDate | date \"15:04\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#b8bb26",
          "foreground_templates": ["{{ if gt .Code 0 }}#fb4934{{ end }}"],
          "template": "{{ if gt .Code 0 }}\uf00d{{ else }}\uf101{{ end }} ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ],
  "transient_prompt": {
    "foreground": "#928374",
    "background": "transparent",
    "template": "\uf101 "
  }
}
